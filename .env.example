# ── frontend (Vite) ───────────────────────────────────────────────────
# Backend dev target used by the /api and /media vite proxy.
VITE_BACKEND_URL="http://localhost:8000"

# Supabase — used only for auth. Everything else lives on Vultr.
# Grab these from the Supabase dashboard (Settings → API).
# anon key is PUBLIC — safe to ship in the browser bundle.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"

# Optional: where google should bounce users back after sign-in.
# Leave blank to default to the current window origin.
VITE_SUPABASE_REDIRECT=""

# ── backend (FastAPI) ────────────────────────────────────────────────
# Supabase JWT secret used to VERIFY user tokens on the server.
# This one is SECRET — never ship to the browser, never commit.
SUPABASE_JWT_SECRET="YOUR_JWT_SECRET"

# Gemini (optional, only if you're hitting the live service).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URL of this deployment (used for oauth redirects, cors, etc).
APP_URL="http://localhost:3000"

# ── vultr object storage (S3-compatible) ─────────────────────────────
# media files (uploads, keyframes, exports) live here. the backend uses
# boto3 against this endpoint. do NOT commit the secret key.
VULTR_S3_ENDPOINT="https://ewr1.vultrobjects.com"
VULTR_S3_REGION="ewr1"
VULTR_S3_BUCKET="iris"
VULTR_S3_ACCESS_KEY=""
VULTR_S3_SECRET_KEY=""
# how media urls are served to the frontend:
#   presigned  → backend mints short-lived GET urls, bucket stays private (recommended)
#   public     → objects are public-read, urls are raw endpoint/bucket/key
MEDIA_URL_MODE="presigned"

# ── vultr managed postgres ──────────────────────────────────────────
# replaces the local sqlite file. must use asyncpg dsn for fastapi.
DATABASE_URL="postgresql+asyncpg://vultradmin:PASSWORD@iris-db.vultrdb.com:16751/iris?ssl=require"
